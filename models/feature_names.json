    "feature_order": [
      "density",
      "opening",
      "thickness",
      "Z",
      "area",
      "n_upper",
      "boundary",
      "sqrt_area",
      "open_len",
      "tz"
    ],
    "derived_features": {
      "area": "length^2",
      "sqrt_area": "length",
      "open_len": "opening * length",
      "tz": "thickness * Z"
    },
    "preprocessing": "Pipeline ColumnTransformer: StandardScaler on numeric and physics-lite features, OneHotEncoder(handle_unknown='ignore') on boundary."
  },
  "beta": {
    "filename": "final_model_beta.joblib",
    "source_filename": "models_constrained_nup2/best_model_beta_HGB_phys.joblib",
